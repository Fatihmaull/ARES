# apps/worker — long-running async worker that consumes jobs from the queue.

# Postgres (same database as apps/web).
DATABASE_URL=postgres://user:pass@host:5432/db?sslmode=require

# Redis-backed queue (BullMQ). Required in production.
ASST_QUEUE_REDIS_URL=

# Worker tuning.
ASST_WORKER_CONCURRENCY=4
ASST_WORKER_HEALTH_PORT=9090

# Repo root used by the engine for skill loading and tool path safety.
ASST_REPO_ROOT=/app

# LLM keys (production budgets enforced upstream).
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Object storage (writes; web only reads via signed URLs).
ASST_OBJECT_STORE_ENDPOINT=
ASST_OBJECT_STORE_REGION=auto
ASST_OBJECT_STORE_BUCKET=
ASST_OBJECT_STORE_ACCESS_KEY_ID=
ASST_OBJECT_STORE_SECRET_ACCESS_KEY=

# Observability.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
