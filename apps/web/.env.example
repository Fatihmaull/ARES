# Public site URL for canonical, Open Graph, sitemap, and robots (no trailing slash).
# Example production: https://ares.example.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# API protection (required in production for /api/* routes).
ASST_WEB_API_KEY=change-me

# Optional explicit repo root for assurance files and read boundaries.
# ASST_REPO_ROOT=/absolute/path/to/repo
