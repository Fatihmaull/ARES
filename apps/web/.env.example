# ──────────────────────────────────────────────────────────────────────────────
# apps/web — production environment template.
# Never commit real secrets. Vercel/Fly should hold the real values.
# ──────────────────────────────────────────────────────────────────────────────

# Public site URL (no trailing slash). Used for canonical / OG / SIWS message domain.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Operator API key (required in production). When set, automation may pass it
# via x-api-key to bypass quota/billing for non-customer traffic.
ASST_WEB_API_KEY=change-me

# Optional explicit repo root for assurance files and read boundaries.
# Use the same absolute path for apps/web and apps/worker so synthesized PDFs in
# `.asst/reports/` are readable by `/api/reports/download` (local-fs artifacts).
# ASST_REPO_ROOT=/absolute/path/to/repo

# ── Auth (SIWS / JWT) ─────────────────────────────────────────────────────────
ASST_SESSION_SECRET=change-me-32+chars
ASST_SESSION_TTL_SECONDS=3600
ASST_SIWS_DOMAIN=localhost:3000

# ── Postgres (Neon recommended) ───────────────────────────────────────────────
DATABASE_URL=postgres://user:pass@host:5432/db?sslmode=require

# ── Redis (Upstash) ───────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Solana / Treasury (legacy memo rail; PayAI is primary in production) ──────
ASST_TREASURY_WALLET=
ASST_DEPOSIT_MINT_USDC=

NEXT_PUBLIC_SOLANA_RPC=
NEXT_PUBLIC_SOLANA_CLUSTER=mainnet-beta

# ── PayAI (primary cash-in rail) ──────────────────────────────────────────────
PAYAI_BASE_URL=https://api.payai.network
PAYAI_API_KEY=
PAYAI_WEBHOOK_SECRET=
PAYAI_MERCHANT_ID=
# Comma-separated SKU ids that should be sold via PayAI (blank = all).
PAYAI_ENABLED_SKUS=starter,growth,premium-pack
# Used to compose the success/cancel return URLs the wallet bounces back to.
PAYAI_RETURN_URL=http://localhost:3000/dashboard/billing
PAYAI_CANCEL_URL=http://localhost:3000/pricing

# ── Object storage (Cloudflare R2 / S3-compatible) ────────────────────────────
ASST_OBJECT_STORE_ENDPOINT=
ASST_OBJECT_STORE_REGION=auto
ASST_OBJECT_STORE_BUCKET=
ASST_OBJECT_STORE_ACCESS_KEY_ID=
ASST_OBJECT_STORE_SECRET_ACCESS_KEY=
ASST_OBJECT_STORE_PUBLIC_BASE_URL=

# ── Worker queue (BullMQ over Redis) ──────────────────────────────────────────
# Redis connection string used by both apps/web (enqueue) and apps/worker (consume).
# Use the same Upstash Redis (Standard plan, NOT REST) or a managed Redis.
ASST_QUEUE_REDIS_URL=

# ── Observability ─────────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── LLM providers (production keys; budget-capped at the provider) ────────────
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# ── Admin allowlist ───────────────────────────────────────────────────────────
ASST_ADMIN_WALLETS=

# Comma-separated wallets that skip balance/debit for chat, scan, target scan, and report synthesis.
# Same behavior as operator traffic for billing only (wallet session still required). Rate limits still apply.
# ASST_UNLIMITED_CREDIT_WALLETS=
