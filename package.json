{
  "name": "ares-workspace",
  "private": true,
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "build": "pnpm -r --filter @asst/web --filter @ares/engine --filter @asst/mcp-server --filter @asst/chain-intake run build",
    "dev": "pnpm -r --filter @asst/web --filter @asst/mcp-server --filter @asst/chain-intake run dev",
    "lint": "pnpm -r --filter @asst/web --filter @ares/engine --filter @asst/mcp-server --filter @asst/chain-intake run lint",
    "typecheck": "pnpm -r --filter @asst/web --filter @ares/engine --filter @asst/mcp-server --filter @asst/chain-intake run typecheck",
    "test": "pnpm -r --filter @asst/web --filter @ares/engine --filter @asst/mcp-server --filter @asst/chain-intake run test"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ],
    "ignoredBuiltDependencies": [
      "core-js",
      "esbuild",
      "sharp"
    ]
  },
  "devDependencies": {
    "@types/node": "^25.6.0"
  }
}
